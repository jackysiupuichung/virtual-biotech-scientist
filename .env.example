# API keys for the virtual-biotech agent backends.
#
# Copy this file to `.env` and fill in the keys you have. The `.env` file is
# gitignored and never committed. The agent harness reads these from the
# environment once the application code lands.
#
# NOTE: the offline demos (arena, CSO spine) need NO keys at all — everything
# below is only for `--live` runs and optional services.
#
# Backend selection order for `--backend auto`:
#   1. ANTHROPIC_API_KEY  (primary)
#   2. OPENAI_API_KEY
#   3. GEMINI_API_KEY / GOOGLE_API_KEY
#   4. Claude Code CLI (no key needed)

# --- Anthropic (primary) ---
ANTHROPIC_API_KEY=

# --- OpenAI-compatible (optional) ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Google Gemini (optional) ---
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Optional model override ---
# VBIO_MODEL=

# --- LLM backends (llm/ package; 3 methods, all OpenAI-compatible) ---
# Pick the active method; scripts default to "local".
#   local = tiny GGUF on your machine via llama-cpp-python -> FREE (no brew/Ollama)
#   llama = university llama.cpp srv                        -> FREE (school hardware)
#   qwen  = hosted Qwen API                                 -> PAID per token (cheap; trial quota usually included)
# VBIO_BACKEND=local
#
# local: no key. Run `uv run python scripts/serve_local.py` in another terminal;
# it downloads a ~350MB GGUF and serves OpenAI /v1 on :8080 (same runtime as the
# university server).
# VBIO_LOCAL_BASE_URL=http://localhost:8080/v1
# VBIO_LOCAL_MODEL=local
#
# llama (university llama.cpp / llama-server, OpenAI-compatible /v1 endpoint):
# VBIO_LLAMA_BASE_URL=http://<campus-host>:8080/v1
# VBIO_LLAMA_MODEL=llama
# LLAMA_API_KEY=            # only if the server requires one
#
# qwen (hosted, OpenAI-compatible — e.g. DashScope): key REQUIRED.
# VBIO_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# VBIO_QWEN_MODEL=qwen-plus
# QWEN_API_KEY=

# --- ToolUniverse (evidence/tool layer; see docs/SETUP.md) ---
# ToolUniverse runs over MCP (uvx tooluniverse) and needs no key for the public
# databases (Open Targets, CELLxGENE, TCGA/GDC, openFDA, ClinicalTrials.gov).
# A few tools are key-gated and simply stay disabled when unset:
# NCBI_API_KEY=       # higher NCBI/PubMed rate limits (optional)
# NVIDIA_API_KEY=     # NVIDIA-hosted models incl. Boltz-2 (optional)
# ONCOKB_API_TOKEN=   # OncoKB precision-oncology tool (optional)

# --- Langfuse (optional tracing mirror; activates only when BOTH keys set) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=  # self-hosted Langfuse base URL; omit for Langfuse Cloud
