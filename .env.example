# API keys for the virtual-biotech agent backends.
#
# Copy this file to `.env` and fill in the keys you have. The `.env` file is
# gitignored and never committed. The agent harness reads these from the
# environment (see skills/virtual-biotech-cso/runners.py).
#
# NOTE: the arena MVP (`python -m arena.run --demo`) and `cso.py --demo` need NO
# keys at all — everything below is only for `--live` runs and optional services.
#
# Backend selection order for `--backend auto`:
#   1. ANTHROPIC_API_KEY  (primary)
#   2. OPENAI_API_KEY
#   3. GEMINI_API_KEY / GOOGLE_API_KEY
#   4. Claude Code CLI (no key needed)

# --- Anthropic (primary) ---
ANTHROPIC_API_KEY=

# --- OpenAI-compatible (optional) ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- Google Gemini (optional) ---
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Optional model override ---
# VBIO_MODEL=

# --- ToolUniverse (evidence/tool layer; see docs/SETUP.md) ---
# ToolUniverse runs over MCP (uvx tooluniverse) and needs no key for the public
# databases (Open Targets, CELLxGENE, TCGA/GDC, openFDA, ClinicalTrials.gov).
# A few tools are key-gated and simply stay disabled when unset:
# NCBI_API_KEY=       # higher NCBI/PubMed rate limits (optional)
# NVIDIA_API_KEY=     # NVIDIA-hosted models incl. Boltz-2 (optional)
# ONCOKB_API_TOKEN=   # OncoKB precision-oncology tool (optional)

# --- Langfuse (optional tracing mirror; activates only when BOTH keys set) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=  # self-hosted Langfuse base URL; omit for Langfuse Cloud
