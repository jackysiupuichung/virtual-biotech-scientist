# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv / venv
.venv/

# Secrets — never commit real env files (keep .env.example tracked)
.env
.env.*
!.env.example

# Generated skill / workflow output + run logs (runtime artifacts, not source).
# On the cluster these are symlinks into /gpfs/scratch/$USER/virtual-biotech-scientist;
# scripts/slurm/*.sh recreate the symlinks + scratch dirs on a fresh checkout.
# No trailing slash: these are symlinks, and `output/` would match only a real dir.
output
logs

# Large raw datasets (download/regenerate, don't commit binaries)
*.h5ad
data/*.h5ad

# Runtime knowledge-graph / state stores (regenerated each run)
kg.json

# macOS
.DS_Store

# Third-party paper PDFs (keep locally, cite by DOI/URL — do not commit binaries)
docs/**/papers/*.pdf
skills/virtual-biotech-cso/eval/out/
