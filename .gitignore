# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv / venv
.venv/

# Secrets — never commit real env files (keep .env.example tracked)
.env
.env.*
!.env.example

# Generated skill / workflow output (runtime artifacts, not source)
output/

# Large raw datasets (download/regenerate, don't commit binaries)
*.h5ad
data/*.h5ad

# Runtime knowledge-graph / state stores (regenerated each run)
kg.json

# macOS
.DS_Store
